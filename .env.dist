# Project
PROJECT_NAME=fnbr-webtool

# Apache2
DOCUMENT_ROOT=.
APACHE_VHOSTS_DIR=./docker/config/vhosts
APACHE_LOG_DIR=./docker/logs/apache2
WWW_PORT=8001

# PHP
PHP_INI=./docker/config/php/php.ini

# Trace
TRACE_PORT=9999
WS_PORT=9998

# Database webtool
DB_NAME=webtool_db
DB_HOST=db_server
DB_PORT=3306
DB_USER=db_user
DB_PASS=db_pass