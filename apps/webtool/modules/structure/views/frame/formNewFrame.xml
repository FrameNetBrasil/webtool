<?xml version="1.0"?>
<view>
    <mformdialog id="formNewFrame">
        <property title="New Frame"  onClose="structure.reloadFrame();"/>
        <fields>
            <mtextfield id="frame_nameEN" width="250px" label="Name [en]"/>
        </fields>
        <tools>
            <mlinkbutton id="lbCloseLU" iconCls="icon-cancel" text="{{_M('Close')}}" plain="true" action="$this->data->close"/>
            <mlinkbutton id="lbSaveLU" iconCls="icon-save" text="{{_M('Save')}}" plain="true" action="$this->data->save"/>
        </tools>
    </mformdialog>
</view>